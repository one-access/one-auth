# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=mock-generated-pass
MAIL_PORT=587

# OAuth2 Configuration
GOOGLE_CLIENT_ID=mock-client-id
GOOGLE_CLIENT_SECRET=mock-client-secret
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Application Configuration
APP_DEBUG_JPA_SHOW_SQL=true
APP_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:4200,http://localhost:3000,http://localhost:3001
OAUTH2_AUTHORIZED_REDIRECT_URIS=http://localhost:8080,http://localhost:4200,http://localhost:3000,http://localhost:3001
